<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Esta acción del cliente lanza nuestro componente OWL -->
        <record id="action_app_dashboard" model="ir.actions.client">
            <field name="name">Apps Dashboard</field>
            <field name="tag">odoodash.app_dashboard</field>
            <field name="target">main</field>
        </record>

        <!-- Menú principal para acceder al dashboard en cualquier momento sin cerrar sesión -->
        <menuitem id="menu_app_dashboard_root"
                  name="Inicio"
                  action="action_app_dashboard"
                  sequence="1"
                  web_icon="odoodash,static/description/icon.png"/>
    </data>
</odoo>
