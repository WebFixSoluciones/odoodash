<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="odoodash.AppDashboard" owl="1">
        <div class="o_home_menu_background">
            <div class="o_home_menu">
                <!-- Barra de Navegación Estilo Odoo Enterprise -->
                <div class="o_home_menu_top_bar">
                    <div class="o_top_bar_right_enterprise">
                        <!-- Botón de Chat (Conversaciones) -->
                        <div class="o_top_bar_item o_chat_button" t-on-click="openDiscuss">
                            <i class="fa fa-comments"/>
                            <span class="o_badge_count">3</span>
                        </div>
                        
                        <!-- Botón de Actividades -->
                        <div class="o_top_bar_item o_activity_button" t-on-click="openDiscuss">
                            <i class="fa fa-clock-o"/>
                            <span class="o_badge_count">1</span>
                        </div>
                        
                        <!-- Icono de Desarrollador (Debug Mode) -->
                        <div class="o_top_bar_item o_debug_button" t-on-click="toggleDebug" t-att-class="{ 'o_debug_active': state.isDebugMode }">
                            <i class="fa fa-wrench"/>
                        </div>

                        <!-- Nombre de la Empresa Activa -->
                        <span class="o_enterprise_company_name" t-esc="state.companyName"/>

                        <!-- Avatar del Usuario (Inicial o imagen) -->
                        <div class="o_enterprise_user_avatar" t-on-click="openPreferences">
                            <t t-if="state.avatarUrl">
                                <img t-att-src="state.avatarUrl" class="o_avatar_img" t-on-error="(ev) => ev.target.style.display = 'none'"/>
                            </t>
                            <span class="o_avatar_initial" t-esc="state.userInitial"/>
                            <span class="o_avatar_status_dot"/>
                        </div>
                    </div>
                </div>

                <div class="o_search_container">
                    <input type="text" placeholder="Buscar aplicación..." 
                           t-model="state.searchQuery" class="o_search_input"/>
                </div>

                <!-- Grid de Aplicaciones -->
                <div class="o_apps">
                    <t t-foreach="filteredApps" t-as="app" t-key="app.id">
                        <a role="menuitem" t-on-click="() => this.openApp(app)" class="o_app o_menuitem" t-att-style="app.styleStr">
                            <div class="o_app_icon_wrapper">
                                <img t-att-src="app.iconUrl" class="o_app_icon" t-att-alt="app.name" t-on-error="(ev) => this.handleIconError(ev, app)"/>
                            </div>
                            <div class="o_caption" t-esc="app.name"/>
                        </a>
                    </t>
                </div>
            </div>
        </div>
    </t>
</templates>
