<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="odoodash.AppDashboard" owl="1">
        <div class="o_home_menu_background">
            <div class="o_home_menu">
                <div class="o_apps">
                    <t t-foreach="state.apps" t-as="app" t-key="app.id">
                        <a role="menuitem" t-on-click="() => this.openApp(app)" class="o_app o_menuitem">
                            <div class="o_app_icon_wrapper">
                                <img t-att-src="app.iconUrl" class="o_app_icon" t-att-alt="app.name"/>
                            </div>
                            <div class="o_caption" t-esc="app.name"/>
                        </a>
                    </t>
                </div>
            </div>
        </div>
    </t>
</templates>
